<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="horizontal"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#121821"
    android:padding="12dp"
    android:layout_marginBottom="8dp"
    android:gravity="center_vertical">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="wrap_content">
        <TextView android:id="@+id/txt_time"
            android:textColor="#FFFFFF" android:textSize="22sp"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <TextView android:id="@+id/txt_days"
            android:textColor="#7C8B9B" android:textSize="12sp"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    </LinearLayout>

    <Switch android:id="@+id/switch_enabled"
        android:layout_width="wrap_content" android:layout_height="wrap_content"/>

    <Button android:id="@+id/btn_delete" android:text="Suppr."
        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
</LinearLayout>
