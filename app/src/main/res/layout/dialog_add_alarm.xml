<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="12dp">

    <TimePicker android:id="@+id/time_picker"
        android:layout_width="match_parent" android:layout_height="wrap_content"/>

    <TextView android:text="Jours (laisser vide = une seule fois)"
        android:layout_marginTop="8dp"
        android:layout_width="wrap_content" android:layout_height="wrap_content"/>

    <LinearLayout android:orientation="horizontal"
        android:layout_width="match_parent" android:layout_height="wrap_content">
        <CheckBox android:id="@+id/cb_day0" android:text="L"/>
        <CheckBox android:id="@+id/cb_day1" android:text="M"/>
        <CheckBox android:id="@+id/cb_day2" android:text="M"/>
        <CheckBox android:id="@+id/cb_day3" android:text="J"/>
        <CheckBox android:id="@+id/cb_day4" android:text="V"/>
        <CheckBox android:id="@+id/cb_day5" android:text="S"/>
        <CheckBox android:id="@+id/cb_day6" android:text="D"/>
    </LinearLayout>
</LinearLayout>
